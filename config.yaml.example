# Database configuration
# Default: SQLite with file "portfolio.db"
#
# Config file location: config/config.yaml
# If config file does not exist, the web setup wizard will guide you through
# initial configuration on first launch.
#
# PostgreSQL:
#   database.type = postgres
#   database.dsn  = postgres://user:pass@localhost:5432/portfolio?sslmode=disable

database:
  type: sqlite          # sqlite | postgres
  dsn: portfolio.db     # SQLite: file path; Postgres: DSN string

# OIDC/SSO configuration (optional)
# Enables SSO login via any OpenID Connect provider (Keycloak, Auth0, etc.)
#
# oidc:
#   enabled: true
#   issuer: https://your-provider.example.com
#   clientID: your-client-id
#   clientSecret: your-client-secret
#   redirectURL: http://localhost:3000/api/auth/oidc/callback
